# Base URL of the Ticketli backend Worker API
BACKEND_BASE_URL=http://localhost:3000

# Admin-role bearer token used to call /admin/discovery/* routes.
# Provision a dedicated admin/service account for this crawler -- do not reuse
# a human admin's personal token.
DISCOVERY_ADMIN_TOKEN=

# How many discovery_queries rows to process per invocation of `pnpm start`.
DISCOVERY_BATCH_SIZE=20

# OpenAI key used by the nitkati_group detail-page AI extractor.
# Keep the real value only in your local .env file.
OPENAI_API_KEY=

# Optional OpenAI model override for listing detail extraction.
OPENAI_MODEL=gpt-5.4-mini

# Set to debug to print the OpenAI prompt payload and parsed model output.
LOG_LEVEL=info
